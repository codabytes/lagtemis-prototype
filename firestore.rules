rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: institutions
    // Fields: name (string), type (string: Public|Private), address (string), website (string)
    //
    // Collection: faculties
    // Fields: name (string), institutionId (string), type (string: faculty|directorate)
    //
    // Collection: departments
    // Fields: name (string), facultyId (string), isSTEM (bool), type (string: department|unit)
    //
    // Collection: students
    // Fields: lasrraId (string), firstName (string), otherName (string), lastName (string), dob (string), sex (string), matricNumber (string), institutionId (string), campus (string), programmeType (string), facultyId (string), departmentId (string), admissionYear (string), enrollmentStatus (string), certificateVerified (bool)
    //
    // Collection: staff
    // Fields: lasrraId (string), staffId (string), title (string), surname (string), firstName (string), otherName (string), gender (string), dob (string), institutionId (string), facultyId (string), departmentId (string), designation (string), gradeLevel (string), dateOfFirstAppointment (string), dateOfConfirmation (string), dateOfLastPromotion (string), highestQualification (string), specialization (string), employmentStatus (string)
    //
    // Collection: publications
    // Fields: staffId (string), outputId (string), title (string), type (string), year (int), abstract (string), fundingSource (string)
    //
    // Collection: facilities
    // Fields: assetId (string), name (string), type (string), institutionId (string), campus (string), location (string), custodianId (string), capacity (int), dateCompleted (string), fundingSource (string)
    //
    // Collection: trainings
    // Fields: trainingId (string), staffId (string), title (string), type (string), date (string), duration (string), location (string), isInternational (bool), provider (string), fundingSource (string)
    //
    // Collection: users
    // Fields: email (string), role (string), institutionId (string)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isDefaultAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "olurantidiyan@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email.matches('(?i)olurantidiyan@gmail\\.com') || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "SuperUser"));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRole(role) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidInstitution() {
      return hasRequiredFields(['name', 'type']) &&
             isValidString('name', 2, 100) &&
             request.resource.data.type in ['Public', 'Private'];
    }

    function isValidFaculty() {
      return hasRequiredFields(['name', 'institutionId', 'type']) &&
             isValidString('name', 2, 100) &&
             request.resource.data.type in ['faculty', 'directorate'];
    }

    function isValidDepartment() {
      return hasRequiredFields(['name', 'facultyId', 'isSTEM', 'type']) &&
             isValidString('name', 2, 100) &&
             request.resource.data.isSTEM is bool &&
             request.resource.data.type in ['department', 'unit'];
    }

    function isValidStudent() {
      return hasRequiredFields(['lasrraId', 'firstName', 'lastName', 'matricNumber', 'institutionId', 'programmeType', 'facultyId', 'departmentId', 'admissionYear', 'enrollmentStatus']) &&
             isValidString('lasrraId', 1, 50) &&
             isValidString('firstName', 1, 50) &&
             isValidString('lastName', 1, 50) &&
             isValidString('matricNumber', 1, 50) &&
             request.resource.data.admissionYear is string &&
             request.resource.data.programmeType in ['Full-time', 'Part-time', 'Sandwich'] &&
             request.resource.data.enrollmentStatus in ['Enrolled', 'Withdrawn', 'Suspended', 'Rusticated'] &&
             (!('campus' in request.resource.data) || request.resource.data.campus is string);
    }

    function isValidStaff() {
      return hasRequiredFields(['lasrraId', 'staffId', 'title', 'surname', 'firstName', 'gender', 'dob', 'institutionId', 'departmentId', 'designation', 'gradeLevel', 'dateOfFirstAppointment', 'dateOfConfirmation', 'dateOfLastPromotion', 'highestQualification', 'employmentStatus', 'staffType']) &&
             request.resource.data.gender in ['Male', 'Female'] &&
             request.resource.data.staffType in ['Academic', 'Non-Academic'] &&
             request.resource.data.employmentStatus in ['Active', 'On Study Leave', 'On Sabbatical', 'On Leave of Absence', 'On Suspension', 'Appointment Terminated', 'Dismissed', 'Retired'];
    }

    function isValidPublication() {
      return hasRequiredFields(['staffId', 'outputId', 'title', 'type', 'year', 'fundingSource']) &&
             request.resource.data.year is int;
    }

    function isValidTraining() {
      return hasRequiredFields(['trainingId', 'staffId', 'title', 'type', 'date', 'duration', 'location', 'isInternational', 'provider', 'fundingSource']) &&
             request.resource.data.isInternational is bool;
    }

    function isValidFacility() {
      return hasRequiredFields(['assetId', 'name', 'type', 'institutionId', 'campus', 'location', 'capacity', 'dateCompleted', 'acquisitionCost', 'fundingSource']) &&
             request.resource.data.capacity is int &&
             (request.resource.data.acquisitionCost is number || request.resource.data.acquisitionCost is int);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || request.auth.token.email == "olurantidiyan@gmail.com");
      allow create: if isAdmin();
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /logs/{id} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /institutions/{id} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || hasRole('DirectorInspection');
      allow update: if isAdmin() || hasRole('DirectorInspection');
      allow delete: if isAdmin();
    }

    match /faculties/{id} {
      allow read: if isAuthenticated();
      allow create: if (isAdmin() || hasRole('DirectorInspection')) && isValidFaculty();
      allow update: if (isAdmin() || hasRole('DirectorInspection')) && isValidFaculty();
      allow delete: if isAdmin();
    }

    match /departments/{id} {
      allow read: if isAuthenticated();
      allow create: if (isAdmin() || hasRole('DirectorInspection')) && isValidDepartment();
      allow update: if (isAdmin() || hasRole('DirectorInspection')) && isValidDepartment();
      allow delete: if isAdmin();
    }

    match /students/{id} {
      allow read: if isAuthenticated();
      allow create: if (isAdmin() || hasRole('DirectorStandards')) && isValidStudent();
      allow update: if (isAdmin() || hasRole('DirectorStandards')) && isValidStudent();
      allow delete: if isAdmin();
    }

    match /staff/{id} {
      allow read: if isAuthenticated();
      allow create: if (isAdmin() || hasRole('DirectorAdminHR') || hasRole('DirectorStandards')) && isValidStaff();
      allow update: if (isAdmin() || hasRole('DirectorAdminHR') || hasRole('DirectorStandards')) && isValidStaff();
      allow delete: if isAdmin();
    }

    match /publications/{id} {
      allow read: if isAuthenticated();
      allow create: if (isAuthenticated() && (isAdmin() || hasRole('DirectorAdminHR'))) && isValidPublication();
      allow update: if (isAdmin() || hasRole('DirectorAdminHR')) && isValidPublication();
      allow delete: if isAdmin();
    }

    match /facilities/{id} {
      allow read: if isAuthenticated();
      allow create: if (isAdmin() || hasRole('DirectorInfrastructure')) && isValidFacility();
      allow update: if (isAdmin() || hasRole('DirectorInfrastructure')) && isValidFacility();
      allow delete: if isAdmin();
    }

    match /maintenance_logs/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isAdmin() || hasRole('DirectorInfrastructure'));
      allow update, delete: if isAdmin();
    }

    match /trainings/{id} {
      allow read: if isAuthenticated();
      allow create: if (isAdmin() || hasRole('DirectorAdminHR')) && isValidTraining();
      allow update: if (isAdmin() || hasRole('DirectorAdminHR')) && isValidTraining();
      allow delete: if isAdmin();
    }

    match /leadership_tenures/{id} {
      allow read, write: if isAdmin();
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
