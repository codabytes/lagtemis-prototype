rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperUser() {
      return isSignedIn() && getUserData().role == 'SuperUser';
    }

    function isDirector() {
      return isSignedIn() && getUserData().role.matches('^Director.*');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidStudent(data) {
      return data.keys().hasAll(['lasrraId', 'firstName', 'lastName', 'matricNumber', 'institutionId', 'programmeType', 'facultyId', 'departmentId', 'admissionYear', 'enrollmentStatus'])
        && data.lasrraId is string && data.lasrraId.size() <= 64
        && data.firstName is string && data.firstName.size() <= 100
        && data.lastName is string && data.lastName.size() <= 100
        && data.matricNumber is string && data.matricNumber.size() <= 50
        && data.institutionId is string && data.institutionId.size() <= 100
        && data.programmeType in ['Full-time', 'Part-time', 'Sandwich']
        && data.enrollmentStatus in ['Enrolled', 'Withdrawn', 'Suspended', 'Rusticated'];
    }

    function isValidStaff(data) {
      return data.keys().hasAll(['lasrraId', 'staffId', 'title', 'surname', 'firstName', 'gender', 'dob', 'institutionId', 'departmentId', 'designation', 'gradeLevel', 'dateOfFirstAppointment', 'employmentStatus', 'staffType', 'email', 'mobilePhone'])
        && data.lasrraId is string && data.lasrraId.size() <= 64
        && data.staffId is string && data.staffId.size() <= 64
        && data.email is string && data.email.size() <= 150
        && data.employmentStatus in ['Active', 'On Study Leave', 'On Sabbatical', 'On Leave of Absence', 'On Suspension', 'Appointment Terminated', 'Dismissed', 'Retired'];
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSuperUser(); 
    }

    match /institutions/{instId} {
      allow read: if isSignedIn();
      allow create, update: if isDirector() || isSuperUser();
      allow delete: if isSuperUser();
    }

    match /faculties/{facId} {
      allow read: if isSignedIn();
      allow create, update: if isDirector() || isSuperUser();
      allow delete: if isSuperUser();
    }

    match /departments/{deptId} {
      allow read: if isSignedIn();
      allow create, update: if isDirector() || isSuperUser();
      allow delete: if isSuperUser();
    }

    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create: if (isDirector() || isSuperUser()) && isValidStudent(incoming());
      allow update: if (isDirector() || isSuperUser()) && isValidStudent(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['firstName', 'otherName', 'lastName', 'dob', 'sex', 'email', 'mobilePhone', 'programmeType', 'facultyId', 'departmentId', 'enrollmentStatus', 'certificateVerified', 'picture', 'updatedAt']);
      allow delete: if isSuperUser();
    }

    match /staff/{staffId} {
      allow read: if isSignedIn();
      allow create: if (isDirector() || isSuperUser()) && isValidStaff(incoming());
      allow update: if (isDirector() || isSuperUser()) && isValidStaff(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'surname', 'firstName', 'otherName', 'gender', 'dob', 'facultyId', 'departmentId', 'designation', 'gradeLevel', 'dateOfConfirmation', 'dateOfLastPromotion', 'highestQualification', 'specialization', 'employmentStatus', 'email', 'mobilePhone', 'picture', 'updatedAt']);
      allow delete: if isSuperUser();
    }

    match /facilities/{facilityId} {
      allow read: if isSignedIn();
      allow write: if isDirector() || isSuperUser();
    }

    match /maintenance_logs/{logId} {
      allow read: if isSignedIn();
      allow write: if isDirector() || isSuperUser();
    }

    match /trainings/{trainingId} {
      allow read: if isSignedIn();
      allow write: if isDirector() || isSuperUser();
    }

    match /publications/{pubId} {
      allow read: if isSignedIn();
      allow write: if isDirector() || isSuperUser();
    }

    match /leadership/{leadId} {
      allow read: if isSignedIn();
      allow write: if isDirector() || isSuperUser();
    }

    match /logs/{logId} {
      allow read: if isSuperUser();
      allow create: if isSignedIn();
    }
  }
}
